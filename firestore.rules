rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: id, name, price, oldPrice, discountPercentage, category, image, unit, stock, description, isActive
    //
    // Collection: categories
    // Fields: id, name, icon, color
    //
    // Collection: orders
    // Fields: id, date, total, status, itemsCount, items, paymentMethod, paymentDetails, deliveryAddress, userId
    //
    // Collection: users
    // Fields: id, name, phone, address, avatar, isAdmin
    //
    // Collection: settings
    // Document: global
    // Fields: isStoreOpen, maintenanceMode, deliveryCharge, minOrderAmount, aiAssistantEnabled, broadcastMessage, storeName, storeSlogan, storeLogo, supportPhone, globalDiscountEnabled, globalDiscountPercentage
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true) ||
         (request.auth.token.email == "tamimshaon@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "admin@bismillah.com"));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      // PII Protection: Only the owner or an admin can read user data
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Products collection
    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // Orders collection
    match /orders/{orderId} {
      // Allow read (get/list) if admin, or if the document belongs to the user
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Settings collection
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
